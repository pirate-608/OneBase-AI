# =========================
# OneBase 特定生成文件
# =========================
# 忽略由 CLI 在本地测试时生成的项目配置和数据
.onebase/
/base/
onebase.yml
*.db
*.sqlite3

# =========================
# 环境变量 (非常重要：防止 API Key 泄露)
# =========================
.env
.env.*
!.env.example

# =========================
# Python 忽略
# =========================
# 字节码
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
.venv/
venv/
env/
ENV/

# PyPI 打包与构建产物 (CI/CD 必备)
build/
dist/
*.egg-info/
.eggs/
*.egg
*.whl
*.tar.gz

# 测试与覆盖率
.pytest_cache/
.tox/
.coverage
htmlcov/

# =========================
# 前端 (Node.js & Vue) 忽略
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite / Vue 打包产物
templates/frontend/dist/
templates/frontend/dist-ssr/
templates/frontend/*.local

# =========================
# IDE 与 操作系统 忽略
# =========================
.vscode/
.idea/
*.swp
.swo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 临时文件
*.tmp
*.log
temp/
test.md