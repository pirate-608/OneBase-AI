# ============================================================
# OneBase 环境变量模板
# 复制为 .env 后按需修改（.env 已在 .gitignore 中排除）
# ============================================================

# --- 数据库 (自动生成，一般无需修改) ---
POSTGRES_USER=onebase
POSTGRES_PASSWORD=          # onebase init 会自动填入随机密码
POSTGRES_DB=onebase_db
POSTGRES_PORT=5432

# --- API 鉴权 (可选) ---
# 设置后所有 /api/* 端点（除 /api/health）需携带 Authorization: Bearer <token>
# 留空则跳过鉴权（适合本地开发）
API_TOKEN=

# --- 推理/嵌入 API 密钥 (按需填写，只填对应 provider) ---
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
ZHIPU_API_KEY=
GROQ_API_KEY=

# --- vLLM gated 模型 (可选) ---
HF_TOKEN=

# --- CORS (生产环境必须设置) ---
# 默认 * 允许所有来源，生产部署请改为实际前端域名
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- 日志格式 (可选) ---
# text = 默认 Rich 文本格式
# json = 结构化 JSON（适合 ELK / Datadog 等日志聚合）
# LOG_FORMAT=text
